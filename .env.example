# ===== Monitor de Câmbio EUR/BRL - Salvador =====
# Copie este arquivo para .env e ajuste os valores.

# Threshold de alerta (R$ por EUR). Vazio = desabilitado.
THRESHOLD_EUR_BRL=

# Webhook opcional para notificações (Slack/Discord/Telegram, etc.)
NOTIFY_WEBHOOK_URL=

# Token do GitHub (usado apenas localmente; no Actions usa-se GITHUB_TOKEN automático)
# GITHUB_TOKEN=
